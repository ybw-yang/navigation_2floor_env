          <ixz>0.0</ixz>
          <iyy>0.0001</iyy>
          <iyz>0.0</iyz>
          <izz>0.0001</izz>
        </inertia>
        <mass>0.05</mass>
      </inertial>

      <collision name="back_lidar_collision">
        <pose>-0.18 0 0.15 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.03</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="back_lidar_visual">
        <pose>-0.18 0 0.15 0 0 0</pose>
