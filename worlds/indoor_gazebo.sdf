<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="indoor_two_story">
    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <model name="two_story_building">
      <static>true</static>

      <link name="structure">
        <!-- 下层地板 -->
        <collision name="floor_lower_collision">
          <pose>0 0 0.05 0 0 0</pose>
          <geometry><box><size>20.4 20.4 0.1</size></box></geometry>
        </collision>
        <visual name="floor_lower_visual">
          <pose>0 0 0.05 0 0 0</pose>
          <geometry><box><size>20.4 20.4 0.1</size></box></geometry>
          <material><ambient>0.7 0.5 0.3 1</ambient></material>
        </visual>

        <!-- 上层地板：为斜坡留出长条洞口 x∈[-0.75,0.75], y∈[-5.6,5.6] -->
        <!-- 左块（x< -0.75） -->
        <collision name="floor_upper_left_block_collision">
          <pose>-5.375 0 3.1 0 0 0</pose>
          <geometry><box><size>9.25 20.0 0.1</size></box></geometry>
        </collision>
        <visual name="floor_upper_left_block_visual">
          <pose>-5.375 0 3.1 0 0 0</pose>
          <geometry><box><size>9.25 20.0 0.1</size></box></geometry>
          <material><ambient>0.9 0.9 0.9 1</ambient></material>
        </visual>
        <!-- 右块（x> 0.75） -->
        <collision name="floor_upper_right_block_collision">
          <pose>5.375 0 3.1 0 0 0</pose>
          <geometry><box><size>9.25 20.0 0.1</size></box></geometry>
        </collision>
        <visual name="floor_upper_right_block_visual">
          <pose>5.375 0 3.1 0 0 0</pose>
          <geometry><box><size>9.25 20.0 0.1</size></box></geometry>
          <material><ambient>0.9 0.9 0.9 1</ambient></material>
        </visual>
        <!-- 前填充块（y<-5.6，填补洞口下方） -->
        <collision name="floor_upper_front_fill_collision">
          <pose>0 -7.9 3.1 0 0 0</pose>
          <geometry><box><size>1.5 4.2 0.1</size></box></geometry>
        </collision>
        <visual name="floor_upper_front_fill_visual">
          <pose>0 -7.9 3.1 0 0 0</pose>
          <geometry><box><size>1.5 4.2 0.1</size></box></geometry>
          <material><ambient>0.9 0.9 0.9 1</ambient></material>
        </visual>
        <!-- 后填充块（y> 5.6，填补洞口上方） -->
        <collision name="floor_upper_back_fill_collision">
          <pose>0 7.8 3.1 0 0 0</pose>
          <geometry><box><size>1.5 4.4 0.1</size></box></geometry>
        </collision>
        <visual name="floor_upper_back_fill_visual">
          <pose>0 7.8 3.1 0 0 0</pose>
          <geometry><box><size>1.5 4.4 0.1</size></box></geometry>
          <material><ambient>0.9 0.9 0.9 1</ambient></material>
        </visual>

        <!-- 外墙（半透明） -->
        <collision name="wall_front_collision"><pose>0 10.1 3.1 0 0 0</pose><geometry><box><size>20.4 0.2 6.2</size></box></geometry></collision>
        <visual name="wall_front_visual"><pose>0 10.1 3.1 0 0 0</pose><geometry><box><size>20.4 0.2 6.2</size></box></geometry><material><ambient>0.95 0.95 0.95 0.3</ambient><diffuse>0.95 0.95 0.95 0.3</diffuse></material></visual>
        <collision name="wall_back_collision"><pose>0 -10.1 3.1 0 0 0</pose><geometry><box><size>20.4 0.2 6.2</size></box></geometry></collision>
        <visual name="wall_back_visual"><pose>0 -10.1 3.1 0 0 0</pose><geometry><box><size>20.4 0.2 6.2</size></box></geometry><material><ambient>0.95 0.95 0.95 0.3</ambient><diffuse>0.95 0.95 0.95 0.3</diffuse></material></visual>
        <collision name="wall_left_collision"><pose>-10.1 0 3.1 0 0 0</pose><geometry><box><size>0.2 20.4 6.2</size></box></geometry></collision>
        <visual name="wall_left_visual"><pose>-10.1 0 3.1 0 0 0</pose><geometry><box><size>0.2 20.4 6.2</size></box></geometry><material><ambient>0.95 0.95 0.95 0.3</ambient><diffuse>0.95 0.95 0.95 0.3</diffuse></material></visual>
        <collision name="wall_right_collision"><pose>10.1 0 3.1 0 0 0</pose><geometry><box><size>0.2 20.4 6.2</size></box></geometry></collision>
        <visual name="wall_right_visual"><pose>10.1 0 3.1 0 0 0</pose><geometry><box><size>0.2 20.4 6.2</size></box></geometry><material><ambient>0.95 0.95 0.95 0.3</ambient><diffuse>0.95 0.95 0.95 0.3</diffuse></material></visual>

        <!-- 下层隔墙（中央横墙开口 4m） -->
        <collision name="wall_L1_H1_left"><pose>-5.85 4.5 1.5 0 0 0</pose><geometry><box><size>7.7 0.15 2.8</size></box></geometry></collision>
        <visual name="wall_L1_H1_left_vis"><pose>-5.85 4.5 1.5 0 0 0</pose><geometry><box><size>7.7 0.15 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>
        <collision name="wall_L1_H1_right"><pose>5.85 4.5 1.5 0 0 0</pose><geometry><box><size>7.7 0.15 2.8</size></box></geometry></collision>
        <visual name="wall_L1_H1_right_vis"><pose>5.85 4.5 1.5 0 0 0</pose><geometry><box><size>7.7 0.15 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>
        <!-- 竖墙保持不变 -->
        <collision name="wall_L1_V1_bottom"><pose>-3.5 -2.5 1.5 0 0 0</pose><geometry><box><size>0.15 7.0 2.8</size></box></geometry></collision>
        <visual name="wall_L1_V1_bottom_vis"><pose>-3.5 -2.5 1.5 0 0 0</pose><geometry><box><size>0.15 7.0 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>
        <collision name="wall_L1_V1_top"><pose>-3.5 7.5 1.5 0 0 0</pose><geometry><box><size>0.15 5.0 2.8</size></box></geometry></collision>
        <visual name="wall_L1_V1_top_vis"><pose>-3.5 7.5 1.5 0 0 0</pose><geometry><box><size>0.15 5.0 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>
        <collision name="wall_L1_V2_bottom"><pose>3.5 -2.5 1.5 0 0 0</pose><geometry><box><size>0.15 7.0 2.8</size></box></geometry></collision>
        <visual name="wall_L1_V2_bottom_vis"><pose>3.5 -2.5 1.5 0 0 0</pose><geometry><box><size>0.15 7.0 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>
        <collision name="wall_L1_V2_top"><pose>3.5 7.5 1.5 0 0 0</pose><geometry><box><size>0.15 5.0 2.8</size></box></geometry></collision>
        <visual name="wall_L1_V2_top_vis"><pose>3.5 7.5 1.5 0 0 0</pose><geometry><box><size>0.15 5.0 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>
        <collision name="wall_L1_bath1"><pose>-7.5 -7.5 1.5 0 0 0</pose><geometry><box><size>4.0 0.15 2.8</size></box></geometry></collision>
        <visual name="wall_L1_bath1_vis"><pose>-7.5 -7.5 1.5 0 0 0</pose><geometry><box><size>4.0 0.15 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>
        <collision name="wall_L1_bath2"><pose>-7.5 7.5 1.5 0 0 0</pose><geometry><box><size>4.0 0.15 2.8</size></box></geometry></collision>
        <visual name="wall_L1_bath2_vis"><pose>-7.5 7.5 1.5 0 0 0</pose><geometry><box><size>4.0 0.15 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>

        <!-- 上层隔墙（中央横墙开口 4m，斜坡从中间穿过，开口已足够） -->
        <collision name="wall_U_H_center_left"><pose>-5.85 0 4.6 0 0 0</pose><geometry><box><size>7.7 0.15 2.8</size></box></geometry></collision>
        <visual name="wall_U_H_center_left_vis"><pose>-5.85 0 4.6 0 0 0</pose><geometry><box><size>7.7 0.15 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>
        <collision name="wall_U_H_center_right"><pose>5.85 0 4.6 0 0 0</pose><geometry><box><size>7.7 0.15 2.8</size></box></geometry></collision>
        <visual name="wall_U_H_center_right_vis"><pose>5.85 0 4.6 0 0 0</pose><geometry><box><size>7.7 0.15 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>
        <!-- 竖墙保持不变 -->
        <collision name="wall_U_V_left_bottom"><pose>-5.5 -5.0 4.6 0 0 0</pose><geometry><box><size>0.15 7.0 2.8</size></box></geometry></collision>
        <visual name="wall_U_V_left_bottom_vis"><pose>-5.5 -5.0 4.6 0 0 0</pose><geometry><box><size>0.15 7.0 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>
        <collision name="wall_U_V_left_top"><pose>-5.5 5.0 4.6 0 0 0</pose><geometry><box><size>0.15 7.0 2.8</size></box></geometry></collision>
        <visual name="wall_U_V_left_top_vis"><pose>-5.5 5.0 4.6 0 0 0</pose><geometry><box><size>0.15 7.0 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>
        <collision name="wall_U_V_right_bottom"><pose>5.5 -5.0 4.6 0 0 0</pose><geometry><box><size>0.15 7.0 2.8</size></box></geometry></collision>
