        <collision name="wall_U_office1"><pose>-8.5 -8.5 4.6 0 0 0</pose><geometry><box><size>2.0 0.15 2.8</size></box></geometry></collision>
        <visual name="wall_U_office1_vis"><pose>-8.5 -8.5 4.6 0 0 0</pose><geometry><box><size>2.0 0.15 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>
        <collision name="wall_U_office2"><pose>-8.5 8.5 4.6 0 0 0</pose><geometry><box><size>2.0 0.15 2.8</size></box></geometry></collision>
        <visual name="wall_U_office2_vis"><pose>-8.5 8.5 4.6 0 0 0</pose><geometry><box><size>2.0 0.15 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>
        <collision name="wall_U_office3"><pose>8.5 -8.5 4.6 0 0 0</pose><geometry><box><size>2.0 0.15 2.8</size></box></geometry></collision>
        <visual name="wall_U_office3_vis"><pose>8.5 -8.5 4.6 0 0 0</pose><geometry><box><size>2.0 0.15 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>
        <collision name="wall_U_office4"><pose>8.5 8.5 4.6 0 0 0</pose><geometry><box><size>2.0 0.15 2.8</size></box></geometry></collision>
        <visual name="wall_U_office4_vis"><pose>8.5 8.5 4.6 0 0 0</pose><geometry><box><size>2.0 0.15 2.8</size></box></geometry><material><ambient>0.9 0.9 0.85 1</ambient></material></visual>

        <!-- 15° 斜坡（绕 X 轴旋转 -15°，roll） -->
        <collision name="ramp_collision">
          <pose>0 0 1.6 -0.2618 0 0</pose>
          <geometry><box><size>1.5 12 0.01</size></box></geometry>
        </collision>
        <visual name="ramp_visual">
          <pose>0 0 1.6 -0.2618 0 0</pose>
          <geometry><box><size>1.5 12 0.01</size></box></geometry>
          <material><ambient>0.5 0.3 0.1 1</ambient></material>
        </visual>
      </link>

      <!-- 下层家具（几乎未变，仅将离斜坡过近的个别物品稍移） -->
      <model name="sofa_part1"><static>true</static><pose>7.5 -8.5 0.35 0 0 0</pose><link name="sofa1_link"><collision name="s1_col"><geometry><box><size>1.0 0.5 0.4</size></box></geometry></collision><visual name="s1_vis"><geometry><box><size>1.0 0.5 0.4</size></box></geometry><material><ambient>0.2 0.2 0.7 1</ambient></material></visual></link></model>
